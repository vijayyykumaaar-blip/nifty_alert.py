import requests
import time
from datetime import datetime, time as dtime
import pytz

TELEGRAM_TOKEN = "8754909402:AAGiudQUtZQeG_LjzF4LcFJ5ca9ScUD7ZN0"
CHAT_ID = "948684099"

IST = pytz.timezone("Asia/Kolkata")
MARKET_OPEN = dtime(9, 15)
MARKET_CLOSE = dtime(15, 30)

def is_market_open():
    now = datetime.now(IST).time()
    today = datetime.now(IST).weekday()
    if today >= 5:
        return False
    return MARKET_OPEN <= now <= MARKET_CLOSE

def send_telegram_alert(message):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    payload = {"chat_id": CHAT_ID, "text": message, "parse_mode": "HTML"}
    try:
        requests.post(url, json=payload, timeout=10)
    except Exception as e:
        print(f"Error: {e}")

def get_nse_candles():
    try:
        headers = {
            "User-Agent": "Mozilla/5.0",
            "Accept": "*/*",
            "Referer": "https://www.nseindia.com"
        }
        session = requests.Session()
        session.get("https://www.nseindia.com", headers=headers, timeout=10)
        url = "https://www.nseindia.com/api/chart-databyindex?index=NIFTY 50&indices=true"
        response = session.get(url, headers=headers, timeout=10)
        data = response.json()
        candles = data['grapthData']
        result = []
        for c in candles[-10:]:
            result.append({'open': c[1], 'close': c[4]})
        return result
    except Exception as e:
        print(f"NSE Error: {e}")
        return None

def check_pattern(candles):
    if candles is None or len(candles) < 4:
        return False, 0
    is_green = [c['close'] > c['open'] for c in candles]
    n = len(is_green)
    if is_green[n-1]:
        return False, 0
    green_count = 0
    for i in range(n-2, -1, -1):
        if is_green[i]:
            green_count += 1
        else:
            break
    if green_count >= 3:
        return True, green_count
    return False, 0

def main():
    print("Nifty 50 NSE Live Alert Started!")
    last_alert_candle = None
    while True:
        now = datetime.now(IST)
        if not is_market_open():
            print("Market closed. Waiting...")
            time.sleep(60)
            continue
        candles = get_nse_candles()
        pattern_found, green_count = check_pattern(candles)
        if pattern_found:
            last_candle = str(candles[-1])
            if last_alert_candle != last_candle:
                last_alert_candle = last_candle
                message = (
                    f"🔴 <b>NIFTY 50 ALERT!</b>\n\n"
                    f"📉 Pattern: {green_count} Green → Red Candle\n"
                    f"🕐 Time: {now.strftime('%H:%M:%S')} IST\n"
                    f"📊 Close: {candles[-1]['close']:.2f}\n\n"
                    f"⚠️ Possible reversal!"
                )
                send_telegram_alert(message)
                print(f"Alert sent!")
        else:
            print(f"[{now.strftime('%H:%M')}] No pattern.")
        time.sleep(60)

if __name__ == "__main__":
    main()
